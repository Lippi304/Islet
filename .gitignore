# .gitignore — files git should never track.
#
# Everything here is a GENERATED output (Xcode rebuilds it from source;
# scripts/release.sh rebuilds the release artifacts). Committing them would
# bloat the repo and cause merge noise.
#
# NOTE: git only treats '#' as a comment at the START of a line. An inline
# "pattern  # comment" does NOT work — the '#...' becomes part of the pattern
# and matches nothing. So every pattern below is bare, comments on their own line.

# Xcode build products (scripts/release.sh writes archive/export output here)
build/

# Xcode intermediate build cache
DerivedData/

# Per-user UI state / settings inside .xcodeproj
*.xcuserstate
*.xcuserdatad/
xcuserdata/

# Release artifacts — the distributable .dmg ends up here
dist/

# macOS Finder metadata
.DS_Store
